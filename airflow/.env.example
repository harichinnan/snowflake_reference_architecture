# =============================================================================
# Airflow stack env -- copy to .env and fill in.  cp .env.example .env
# (.env is git-ignored.)  Data is SYNTHETIC -- not real CMS/Medicare/Medicaid/PHI.
# =============================================================================

# Run Airflow containers as your host UID so mounted ./logs are writable.
# macOS/Linux: run `id -u` and paste the value (default 50000 works on macOS).
AIRFLOW_UID=50000

# Airflow web login (created by airflow-init).
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=admin

# --- Snowflake connection used by Cosmos (conn_id: snowflake_claims) ----------
# Airflow reads this JSON as the connection. Fill account/user/password/role.
# account = your locator, e.g. VHYCQZG-PO12637 (NOT the full URL).
# Keep credentials out of git -- this lives only in .env.
AIRFLOW_CONN_SNOWFLAKE_CLAIMS={"conn_type":"snowflake","login":"YOUR_USER","password":"YOUR_PASSWORD","schema":"CONTROL","extra":{"account":"YOUR_ORG-YOUR_ACCOUNT","warehouse":"WH_CLAIMS_TRANSFORM","database":"CLAIMS_DEV","role":"CLAIMS_TRANSFORMER"}}

# Key-pair alternative (recommended for shared/headless): instead of password,
# put "private_key_file":"/opt/airflow/keys/rsa_key.p8" in extra and mount the
# key into the container; drop "password".
