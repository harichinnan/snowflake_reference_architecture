# =============================================================================
# snowflake-claims-platform — .gitignore
# Snowflake-centric project. Keep secrets, state, and generated data out.
# =============================================================================

# --- Python ------------------------------------------------------------------
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
.venv/
venv/
env/
.python-version

# --- dbt local profile (real connection; template is profiles.yml.example) ----
dbt/profiles.yml

# --- dbt ---------------------------------------------------------------------
dbt/target/
dbt/dbt_packages/
dbt/logs/
target/
dbt_packages/
logs/
.user.yml

# --- Terraform (Snowflake provider) ------------------------------------------
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
crash.log
# Ignore real tfvars but KEEP examples.
*.tfvars
!*.tfvars.example

# --- Environment / secrets ---------------------------------------------------
.env
.env.*
!.env.example

# --- Private keys (key-pair auth preferred — never commit keys) --------------
*.p8
*.pem
*.key

# --- SnowSQL / Snowflake CLI local config ------------------------------------
.snowsql/
config.toml
snowsql_config
# Repo-local snow CLI home (contains real account locator; template is
# snowflake/connections.toml.example).
.snowflake/

# --- Generated synthetic data (keep the folder, not its contents) ------------
data_generator/output/*.json
data_generator/output/*.ndjson
data_generator/output/*.gz
data_generator/output/*.csv
!data_generator/output/.gitkeep

# --- Airflow runtime (containers write these) --------------------------------
airflow/logs/
airflow/plugins/

# --- k8s real secret (keep the .example) -------------------------------------
k8s/snowflake-connection.secret.yaml

# --- OS / IDE ----------------------------------------------------------------
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~
