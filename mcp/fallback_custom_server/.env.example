# snowflake-claims-platform :: FALLBACK MCP server environment (example)
# Copy to .env and fill in. NEVER commit a real .env.
# All data is SYNTHETIC. Prefer the Snowflake-managed MCP server over this.

# --- Connection (required) ---
SNOWFLAKE_ACCOUNT=<ORG>-<ACCOUNT>
SNOWFLAKE_USER=<MCP_SERVICE_USER>

# --- Auth: set ONE block. Priority: externalbrowser > key-pair > password ---
#
# (a) externalbrowser (SSO) — best for LOCAL DEV. Opens a browser to log in.
#     Requires a machine WITH a browser (not headless). No key/password needed.
# SNOWFLAKE_AUTHENTICATOR=externalbrowser
#
# (b) key-pair — PREFERRED for HEADLESS / service users.
SNOWFLAKE_PRIVATE_KEY_PATH=/ABSOLUTE/PATH/TO/rsa_key.p8
# SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=<optional-passphrase>
#
# (c) password — supported but NOT recommended.
# SNOWFLAKE_PASSWORD=<password>

# --- Least-privilege session (defaults shown) ---
SNOWFLAKE_ROLE=CLAIMS_MCP_READER
SNOWFLAKE_WAREHOUSE=WH_CLAIMS_MCP
SNOWFLAKE_DATABASE=CLAIMS_DEV
SNOWFLAKE_SCHEMA=SEMANTIC

# --- Guardrails ---
MCP_MAX_ROWS=1000
MCP_QUERY_TIMEOUT_SECONDS=60
MCP_LOG_LEVEL=INFO

# --- Cortex Analyst (optional; only if enabled in the account) ---
# SNOWFLAKE_PAT=<short-lived programmatic access token for REST auth>
# SNOWFLAKE_TOKEN_TYPE=PROGRAMMATIC_ACCESS_TOKEN
# CORTEX_SEMANTIC_MODEL_FILE=@CLAIMS_DEV.SEMANTIC.SEMANTIC_MODELS/claims_semantic_model.yaml
