# =============================================================================
# snowflake-claims-platform — environment template
# -----------------------------------------------------------------------------
# Copy to .env and fill in. NEVER commit .env or real secrets.
#   cp .env.example .env
#
# This platform is 100% Snowflake. There are NO AWS/Azure/GCP credentials here,
# because there is NO external object storage (S3/GCS/Blob), no Airflow, etc.
# Ingestion is Snowflake internal stages + PUT + COPY INTO only.
#
# Data is SYNTHETIC — not real CMS/Medicare/Medicaid/PHI.
# =============================================================================

# --- Local toolchain ---------------------------------------------------------
# All tooling runs from ./.venv (Python 3.13). Create it with: make venv
# The Makefile sets SNOWFLAKE_HOME=$(PWD)/.snowflake and DBT_PROFILES_DIR=$(PWD)/dbt
# so `snow` and `dbt` use the repo-local, git-ignored configs.
SNOWFLAKE_HOME=./.snowflake
# Named snow CLI connection (defined in .snowflake/config.toml).
SNOWFLAKE_CONNECTION=my_example_connection

# --- Snowflake connection ----------------------------------------------------
# Account identifier, e.g. ORGNAME-ACCOUNTNAME (or the legacy locator form).
SNOWFLAKE_ACCOUNT=your_org-your_account

# Service / user name used by loaders, dbt, and CI.
SNOWFLAKE_USER=claims_service_user

# --- Authentication ----------------------------------------------------------
# externalbrowser (SSO) is the simplest for LOCAL dev — no secret stored; a
# browser window opens to authenticate. This is what .snowflake/config.toml and
# dbt/profiles.yml use by default. Options: externalbrowser | snowflake_jwt |
# snowflake (password).
SNOWFLAKE_AUTHENTICATOR=externalbrowser

# KEY-PAIR AUTH IS PREFERRED FOR CI/HEADLESS. Point to your .p8 key.
# Private keys (*.p8) are git-ignored. Do NOT commit them.
SNOWFLAKE_PRIVATE_KEY_PATH=/absolute/path/to/rsa_key.p8
# If your key has a passphrase, set it here (otherwise leave blank).
SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=

# Password auth is a FALLBACK ONLY. Prefer key-pair or SSO above. Leave blank
# when using key-pair or externalbrowser auth.
SNOWFLAKE_PASSWORD=

# --- Role / compute / namespace ----------------------------------------------
# Use the least-privilege role appropriate to the task:
#   CLAIMS_LOADER (stage+COPY), CLAIMS_TRANSFORMER (dbt), CLAIMS_ANALYST (read),
#   CLAIMS_CI (CI builds), CLAIMS_MCP_READER (MCP), CLAIMS_SECURITY_ADMIN (grants),
#   CLAIMS_SYSADMIN (objects).
SNOWFLAKE_ROLE=CLAIMS_TRANSFORMER

# Warehouses: WH_CLAIMS_LOAD | WH_CLAIMS_TRANSFORM | WH_CLAIMS_ANALYST |
#             WH_CLAIMS_CI | WH_CLAIMS_MCP
SNOWFLAKE_WAREHOUSE=WH_CLAIMS_TRANSFORM

# Database: CLAIMS_DEV (dev/CI) or CLAIMS_PROD (production).
SNOWFLAKE_DATABASE=CLAIMS_DEV

# Default schema for ad-hoc work (dbt overrides per-model schema).
SNOWFLAKE_SCHEMA=SILVER_CANONICAL

# --- dbt / pipeline ----------------------------------------------------------
# dbt target profile: dev | prod | ci
DBT_TARGET=dev

# Logical environment used by Makefile / Terraform: dev | prod
ENV=dev
